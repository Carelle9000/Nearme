rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ─────────────────────────────────────────────────────────────────────
    // Helpers
    // ─────────────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isUser(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ─────────────────────────────────────────────────────────────────────
    // profiles/{uid} — User profile data
    // ─────────────────────────────────────────────────────────────────────

    match /profiles/{uid} {
      allow read: if isAuth();
      allow write: if isUser(uid);

      // Subcollections

      match /sent_likes/{targetId} {
        allow read, write: if isUser(uid);
      }

      match /nopes/{targetId} {
        allow read, write: if isUser(uid);
      }

      match /received_likes/{senderId} {
        allow read: if isUser(uid);
        allow write: if isAuth(); // Allow others to like/unlike (create/update/delete)
      }

      match /favorites/{targetId} {
        allow read, write: if isUser(uid);
      }

      match /notifications/{notifId} {
        allow read: if isUser(uid);
        allow update: if isUser(uid); // Mark as read
        allow create: if isAuth(); // Allow others to send notifications (likes, matches)
      }
    }

    // ─────────────────────────────────────────────────────────────────────
    // matches/{matchId} — User matches
    // ─────────────────────────────────────────────────────────────────────

    match /matches/{matchId} {
      // Allow read if user is in the 'users' array
      allow read: if isAuth() && request.auth.uid in resource.data.users;

      // Allow create if user is in the 'users' array being set
      allow create: if isAuth() && request.auth.uid in request.resource.data.users;
    }

    // ─────────────────────────────────────────────────────────────────────
    // conversations/{conversationId} — Chat conversations
    // ─────────────────────────────────────────────────────────────────────

    match /conversations/{conversationId} {
      // Allow read if user is a participant
      allow read: if isAuth() && request.auth.uid in resource.data.participants;

      // Allow create only if both users are matched
      allow create: if isAuth() && 
        request.auth.uid in request.resource.data.participants &&
        request.resource.data.participants.size() == 2 &&
        exists(/databases/$(database)/documents/matches/$(conversationId));

      // Allow update if user is a participant
      allow update: if isAuth() && request.auth.uid in resource.data.participants;

      // Allow delete if user is a participant
      allow delete: if isAuth() && request.auth.uid in resource.data.participants;

      // Messages subcollection
      match /messages/{messageId} {
        // Allow read if user is a participant in the conversation
        allow read: if isAuth() && 
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;

        // Allow create if user is authenticated and is the sender
        allow create: if isAuth() && 
          request.auth.uid == request.data.senderId &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;

        // Allow update if user is the sender (for marking as read)
        allow update: if isAuth() && 
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      }

      // Typing indicators subcollection
      match /typing/{userId} {
        // Allow read if user is a participant
        allow read: if isAuth() && 
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;

        // Allow create/update if user is the one typing
        allow create, update: if isAuth() && request.auth.uid == userId;

        // Allow delete if user is the one who created it
        allow delete: if isAuth() && request.auth.uid == userId;
      }
    }

    // ─────────────────────────────────────────────────────────────────────
    // Old collections (backward compatibility or cleanup)
    // ─────────────────────────────────────────────────────────────────────

    match /likes/{likeId} {
      allow read, write: if false; // Migrated to profiles/{uid}/sent_likes
    }

    match /sharedSpots/{spotId} {
      allow read: if isAuth();
      allow create, update, delete: if isAuth() && isUser(resource.data.userId);
    }

    match /blocks/{blockId} {
      allow read: if isAuth() && (isUser(resource.data.blockerId) || isUser(resource.data.blockedId));
      allow create: if isAuth() && isUser(request.data.blockerId);
      allow delete: if isAuth() && isUser(resource.data.blockerId);
    }

    match /reports/{reportId} {
      allow read: if isAuth() && isUser(resource.data.reporterId);
      allow create: if isAuth() && isUser(request.data.reporterId);
      // Only admins can update reports (status changes)
      allow update: if false;
    }

    match /subscriptions/{uid} {
      allow read, write: if isUser(uid);
    }

    match /users/{uid} {
      allow read, write: if isUser(uid);
    }

    match /verificationLogs/{logId} {
      allow write: if isAuth();
      allow read: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
