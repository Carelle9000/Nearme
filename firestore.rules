rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ─────────────────────────────────────────────────────────────────────
    // Helpers
    // ─────────────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isUser(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ─────────────────────────────────────────────────────────────────────
    // profiles/{uid} — User profile data
    // ─────────────────────────────────────────────────────────────────────

    match /profiles/{uid} {
      allow read: if isAuth();
      allow write: if isUser(uid);

      // Subcollections

      match /sent_likes/{targetId} {
        allow read, write: if isUser(uid);
      }

      match /nopes/{targetId} {
        allow read, write: if isUser(uid);
      }

      match /received_likes/{senderId} {
        allow read: if isUser(uid);
        allow write: if isAuth(); // Allow others to like/unlike (create/update/delete)
      }

      match /favorites/{targetId} {
        allow read, write: if isUser(uid);
      }

      match /notifications/{notifId} {
        allow read: if isUser(uid);
        allow update: if isUser(uid); // Mark as read
        allow create: if isAuth(); // Allow others to send notifications (likes, matches)
      }
    }

    // ─────────────────────────────────────────────────────────────────────
    // matches/{matchId} — User matches
    // ─────────────────────────────────────────────────────────────────────

    match /matches/{matchId} {
      // Allow read if user is in the 'users' array
      allow read: if isAuth() && request.auth.uid in resource.data.users;

      // Allow create if user is in the 'users' array being set
      allow create: if isAuth() && request.auth.uid in request.resource.data.users;

      match /messages/{messageId} {
        allow read: if isAuth() && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.users;
        allow create: if isAuth() && isUser(request.data.senderId);
        allow update: if isAuth() && request.resource.data.readAt != null;
      }
    }

    // ─────────────────────────────────────────────────────────────────────
    // Old collections (backward compatibility or cleanup)
    // ─────────────────────────────────────────────────────────────────────

    match /likes/{likeId} {
      allow read, write: if false; // Migrated to profiles/{uid}/sent_likes
    }

    match /sharedSpots/{spotId} {
      allow read: if isAuth();
      allow create, update, delete: if isAuth() && isUser(resource.data.userId);
    }

    match /blocks/{blockId} {
      allow read: if isAuth() && (isUser(resource.data.blockerId) || isUser(resource.data.blockedId));
      allow create, delete: if isAuth() && isUser(request.data.blockerId);
    }

    match /subscriptions/{uid} {
      allow read, write: if isUser(uid);
    }

    match /users/{uid} {
      allow read, write: if isUser(uid);
    }

    match /verificationLogs/{logId} {
      allow write: if isAuth();
      allow read: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
