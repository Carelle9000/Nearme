rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection
    match /users/{userId} {
      // Users can read their own document
      allow read: if request.auth.uid == userId;

      // Users can create their own document during signup
      // ageVerified field must NOT be present in creation
      // Email validation and age validation done by Cloud Functions
      allow create: if request.auth.uid == userId &&
                       !('ageVerified' in request.resource.data) &&
                       !('age' in request.resource.data) &&
                       request.resource.data.birthYear != null &&
                       request.resource.data.firstName != null;

      // Users can update their own document, but NOT ageVerified, email, or age fields
      allow update: if request.auth.uid == userId &&
                       !('ageVerified' in request.resource.data) &&
                       !('email' in request.resource.data) &&
                       !('age' in request.resource.data);

      // Cloud Functions ONLY can write (set ageVerified after verification)
      allow write: if false;
    }

    // Verification sessions - restricted to owner only
    match /verificationSessions/{sessionId} {
      allow read: if request.auth.uid == resource.data.userId;
      allow create: if request.auth.uid == request.resource.data.userId;
      allow update: if request.auth.uid == resource.data.userId;
    }
  }
}
