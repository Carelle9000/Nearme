rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // ─────────────────────────────────────────────────────────────────────
    // photos/{userId}/{filename} — User profile photos
    // ─────────────────────────────────────────────────────────────────────

    match /photos/{userId}/{allPaths=**} {
      // Authenticated users can read (for discovering other profiles)
      allow read: if request.auth != null;

      // Only the owner can write (upload) to their folder
      allow write: if request.auth != null &&
                      request.auth.uid == userId &&
                      request.resource.size < 5 * 1024 * 1024 && // 5MB max per file
                      request.resource.contentType.matches('image/.*'); // Images only

      // Only the owner can delete their photos
      allow delete: if request.auth != null &&
                       request.auth.uid == userId;
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
