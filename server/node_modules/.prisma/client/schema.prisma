generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Utilisateurs ──────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  profile       Profile?
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ── Profils ───────────────────────────────────────────────────────────────────

model Profile {
  id             String   @id @default(uuid())
  userId         String   @unique @map("user_id")
  name           String
  gender         String?
  heightCm       Float?   @map("height_cm")
  bio            String?
  intention      String?
  location       String?
  interestsJson  String   @default("[]") @map("interests_json")
  photosJson     String   @default("[]") @map("photos_json")
  isFaceVerified Boolean  @default(false) @map("is_face_verified")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ── Interactions ──────────────────────────────────────────────────────────────

model Like {
  id         String   @id @default(uuid())
  fromUserId String   @map("from_user_id")
  toUserId   String   @map("to_user_id")
  superLike  Boolean  @default(false) @map("super_like")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([fromUserId, toUserId])
  @@map("likes")
}

model Match {
  id        String   @id @default(uuid())
  userId1   String   @map("user_id_1")
  userId2   String   @map("user_id_2")
  matchedAt DateTime @default(now()) @map("matched_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  messages Message[]

  @@unique([userId1, userId2])
  @@map("matches")
}

model Message {
  id        String    @id @default(uuid())
  matchId   String    @map("match_id")
  senderId  String    @map("sender_id")
  text      String
  sentAt    DateTime  @default(now()) @map("sent_at")
  readAt    DateTime? @map("read_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// ── Géo / Social ──────────────────────────────────────────────────────────────

model SharedSpot {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  lat       Float
  lng       Float
  visitedAt DateTime @map("visited_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("shared_spots")
}

model Block {
  blockerId String @map("blocker_id")
  blockedId String @map("blocked_id")

  @@id([blockerId, blockedId])
  @@map("blocks")
}

model Subscription {
  userId    String    @id @map("user_id")
  plan      String    @default("free")
  expiresAt DateTime? @map("expires_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")

  @@map("subscriptions")
}
