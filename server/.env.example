# Copier en .env et remplir les valeurs
# cp .env.example .env

# ── Base de données ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://nearme:changeme@localhost:5432/nearme"

# ── JWT ────────────────────────────────────────────────────────────────────────
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=remplace_par_64_caracteres_aleatoires
JWT_REFRESH_SECRET=remplace_par_autre_64_caracteres_aleatoires

# ── Face++ (optionnel) ─────────────────────────────────────────────────────────
FACE_PLUS_PLUS_KEY=
FACE_PLUS_PLUS_SECRET=

# ── Serveur ────────────────────────────────────────────────────────────────────
PORT=8080
